
RewriteRule ^privacy\.html$ - [L]
RewriteRule ^terms\.html$ - [L]

# Browser Cache
<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresDefault "access plus 24 hours"
	ExpiresByType text/html "access plus 2 hours"
	ExpiresByType image/jpg "access plus 1 year"
	ExpiresByType image/jpeg "access plus 1 year"
	ExpiresByType image/gif "access plus 1 year"
	ExpiresByType image/png "access plus 1 year"
	ExpiresByType image/webp "access plus 1 year"
	ExpiresByType text/css "access plus 1 month"
	ExpiresByType text/javascript "access plus 1 month"
	ExpiresByType application/pdf "access plus 1 week"
	ExpiresByType image/x-icon "access plus 1 year"
</IfModule>

# Serve static files directly, 404 for missing static assets
<IfModule mod_rewrite.c>
	RewriteEngine On
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} !(robots\.txt|ads\.txt|[a-z0-9_\-]*sitemap[a-z0-9_\.\-]*\.(xml|xsl|html)(\.gz)?)
	RewriteCond %{REQUEST_URI} \.(css|htc|less|js|html|htm|xml|asf|avi|avif|bmp|doc|docx|eot|gif|gz|gzip|ico|jpg|jpeg|jpe|webp|json|mid|midi|mov|mp3|m4a|mp4|m4v|mpeg|mpg|mpe|webm|otf|odb|odc|odf|odg|odp|ods|odt|ogg|ogv|pdf|png|ppt|pptx|svg|svgz|swf|tar|tif|tiff|ttf|ttc|wav|wma|woff|woff2|xls|xlsx|zip)$ [NC]
	RewriteRule .* - [L]
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php83" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83___lsphp .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit
